@using Chirp.Infrastructure.Data
@using Chirp.Infrastructure.Entities
@using Microsoft.AspNetCore.Identity
@inject UserManager<Author> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"]</title>
    <link href="/css/style.css" rel="stylesheet" type="text/css" />
    <link rel="icon" type="image/png" href="/images/magikarp.png">
</head>
<body>
<div class=page>
    <h1><img src="/images/magikarp.png" alt="Icon1"/>Chirp!</h1>
    <!-- Nav bar taken from session 8 README_PROJECT -->
    <div class=navigation>
        @if (User.Identity!.IsAuthenticated)
        {
            <div>
                @{
                    var currentUser = await UserManager.GetUserAsync(User);
                    var displayName = currentUser?.Name ?? User.Identity.Name;
                }
                <a href="/@displayName">my timeline</a> |
                <a href="/">public timeline</a> |
                <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/logout"> Logout [@displayName]</a>
            </div>
        }
        else
        {
            <div>
                <a href="/">public timeline</a> |
                <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">register</a>
                <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">login</a>
            </div>
        }
    </div>
    <div class=body>
            @RenderBody()
    </div>
    <div class=footer style="display: flex; justify-content: space-between">
        Chirp &mdash; An ASP.NET Application
        <p id="tglStrMd" onmouseover="" style="cursor:pointer; margin: 0; padding: 0" onclick="toggleStrokeMode()">Activate Stroke Mode!</p>
    </div>
</div>

</body>
@await RenderSectionAsync("Scripts", required: false)

<script>
    let delay = 50;
    let strokeModeInterval = null;
    let defaultBackgroundColor = document.body.style.backgroundColor;
    
    function randHexColor() {
        return "#" + Math.floor(Math.random() * 16777215).toString(16).padStart(6, "0");
    }
    
    function toggleStrokeMode() {
        
        const button = document.getElementById("tglStrMd");
        if (strokeModeInterval === null) {
            strokeModeInterval = setInterval(() => {
                document.body.style.backgroundColor = randHexColor();
            }, delay)
            button.textContent = "Stop this madness!";
        } else {
            clearInterval(strokeModeInterval);
            strokeModeInterval = null;
            document.body.style.backgroundColor = defaultBackgroundColor;
            button.textContent = "Activate Stroke Mode!";
        }
    }
</script>

</html>
